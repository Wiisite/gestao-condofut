# Configuração do Banco de Dados PostgreSQL
# Local: postgresql://postgres:sua_senha@localhost:5432/escolafut
# VPS:   postgresql://usuario:senha@ip_da_vps:5432/escolafut
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/escolafut

# Chave secreta para sessões (gere uma string aleatória segura de 64+ caracteres)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=sua_chave_secreta_aqui_mude_em_producao

# URL Base da Aplicação (Para retornos do Mercado Pago)
APP_URL=https://seu-dominio.com

# Mercado Pago - Chaves de Produção
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MERCADOPAGO_CLIENT_ID=0000000000000000
MERCADOPAGO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (opcional - para pagamentos alternativos)
# STRIPE_SECRET_KEY=sk_test_...
